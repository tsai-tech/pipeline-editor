{
  "name": "feature",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/board/feature/src",
  "prefix": "pe",
  "projectType": "library",
  "tags": ["scope:board", "type:feature"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "defaultConfiguration": "production",
      "options": {
        "project": "packages/board/feature/ng-package.json",
        "tsConfig": "packages/board/feature/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "packages/board/feature/tsconfig.lib.prod.json"
        },
        "development": {}
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/angular:unit-test",
      "options": {
        "watch": false
      }
    }
  }
}
